{
  "name": "openeuler-portal",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "scripts": {
    "predev": "node scripts/sync-opendesign-skills.js",
    "dev": "vitepress dev app",
    "build": "node scripts/check-git-shallow.js && vitepress build app && node scripts/generate-llms-txt.js",
    "build:geo": "node scripts/check-git-shallow.js && vitepress build app --exclude=**/blog/**/*,**/news/**/*",
    "lint": "eslint \"app/.vitepress/src/**/*.{js,ts,vue,jsx,tsx}\"",
    "fix": "eslint --fix \"app/.vitepress/src/**/*.{js,ts,vue,jsx,tsx}\"",
    "preview": "vitepress preview app",
    "lint:components": "eslint \"opendesign/**/*.{js,ts,vue,jsx,tsx}\"",
    "gen:token": "opensig-scripts gen:token --config ./app/.vitepress/src-new/tokens/token.config.ts",
    "prepare": "husky install",
    "postinstall": "pnpm skills:sync",
    "lint:style": "stylelint \"app/.vitepress/**/*.(vue|scss)\" --fix",
    "skills:sync": "node scripts/sync-opendesign-skills.js"
  },
  "keywords": [],
  "author": "",
  "license": "",
  "dependencies": {
    "@opendesign-plus/components": "0.0.1-rc.54",
    "@opendesign-plus/composables": "0.0.1-rc.10",
    "@opendesign-plus/geo-scripts": "0.0.1-rc.1",
    "@opendesign-plus/plugins": "0.0.1-rc.7",
    "@opensig/open-analytics": "^0.0.8",
    "@opensig/opendesign": "1.2.4",
    "@opensig/opendesign-token": "0.0.11",
    "@vueuse/core": "10.11.1",
    "aos": "^2.3.4",
    "axios": "1.16.1",
    "clipboard": "2.0.11",
    "dayjs": "1.11.13",
    "echarts": "^5.5.1",
    "element-plus": "2.9.5",
    "js-base64": "^3.7.5",
    "js-cookie": "3.0.7",
    "js-yaml": "^4.1.1",
    "markdown-it": "14.1.1",
    "markdown-it-anchor": "8.6.7",
    "mermaid": "11.15.0",
    "opendesign": "./opendesign",
    "pinia": "^2.0.13",
    "swiper": "12.1.2",
    "uuid": "14.0.0",
    "vue": "3.5.29",
    "vue-dompurify-html": "^4.0.0",
    "vue-i18n": "latest",
    "vue-pdf-embed": "^2.1.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@opensig/opensig-scripts": "^0.0.16",
    "@types/aos": "^3.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "14.1.1",
    "@types/node": "^18.0.1",
    "@typescript-eslint/eslint-plugin": "^5.30.5",
    "@typescript-eslint/parser": "^5.30.5",
    "@vitejs/plugin-vue-jsx": "^1.3.10",
    "@vitest/coverage-v8": "3",
    "@vue/compiler-sfc": "3.5.13",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.2.0",
    "cheerio": "^1.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^9.31.0",
    "glob": "^11.0.2",
    "husky": "^8.0.1",
    "lint-staged": "^13.0.3",
    "minimatch": "^10.2.5",
    "p-limit": "^7.3.0",
    "prettier": "^2.7.1",
    "sass": "^1.79.3",
    "turndown": "^7.2.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "8.55.0",
    "unplugin-element-plus": "^0.4.1",
    "unplugin-icons": "^0.14.1",
    "vite-plugin-static-copy": "^2.2.0",
    "vitepress": "1.6.4",
    "vitest": "3.2.6"
  },
  "lint-staged": {
    "app/.vitepress/src/**/*.{js,ts,vue,jsx,tsx}": [
      "pnpm lint"
    ]
  }
}
