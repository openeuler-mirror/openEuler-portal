        {
          "@type": "HowToStep",
          "position": 1,
          "name": "Install VirtualBox",
          "text": "Download the VirtualBox installer from the VirtualBox official website (https://www.virtualbox.org/wiki/Downloads). Use a custom installation path such as D:\software\Oracle\VirtualBox and use default settings for subsequent steps. After installation, press Ctrl+G to open global settings and change the default VM location.",
          "url": "https://www.openeuler.org/en/wiki/install/virtualization#virtualbox-installation"
        },
        {
          "@type": "HowToStep",
          "position": 2,
          "name": "Create a Virtual Machine",
          "text": "In VirtualBox, choose Machine > New. Set Name to openEuler, Type to Linux, and Version to Other Linux (64-bit). Allocate 4 GB (4,096 MB) of memory. Choose to create a virtual hard disk now, select VDI (VirtualBox Disk Image) as the file type, and select Dynamically allocated storage.",
          "url": "https://www.openeuler.org/en/wiki/install/virtualization#vm-creation"
        }
