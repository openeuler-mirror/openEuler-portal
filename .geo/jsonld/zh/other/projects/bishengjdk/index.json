    "programmingLanguage": "Java",
    "softwareVersion": "8, 11, 17, 21",
    "releaseNotes": "支持Java LTS版本：8、11、17、21。支持架构：Linux/AArch64、Linux/x86_64。",
    "featureList": [
      "高性能Java虚拟机",
      "ARM架构性能优化",
