  {
    "@context": "https://schema.org",
    "@type": "SoftwareSourceCode",
    "name": "嵌入式实时虚拟机ZVM（Zephyr-based Virtual Machine）",
    "description": "嵌入式实时虚拟机ZVM是由湖南大学嵌入式与网络计算湖南省重点实验室主任谢国琪教授主导设计并开发的虚拟化软件。该软件基于实时操作系统（RTOS）Zephyr开发，可同时启动Linux与Zephyr 2个Guest OS，从而在同一硬件平台上实现混合内核部署。",
    "codeRepository": "https://www.openeuler.org/",
    "programmingLanguage": "C",
    "author": {
      "@type": "Person",
      "name": "谢国琪",
      "affiliation": {
        "@type": "EducationalOrganization",
        "name": "湖南大学嵌入式与网络计算湖南省重点实验室"
      }
    },
    "datePublished": "2023-02",
    "isPartOf": {
      "@type": "SoftwareApplication",
      "name": "openEuler",
      "url": "https://www.openeuler.org/"
    }
