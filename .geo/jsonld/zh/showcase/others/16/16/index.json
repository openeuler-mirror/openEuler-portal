    "about": {
      "@type": "SoftwareApplication",
      "name": "STARGIS EARTH",
      "applicationCategory": "地理信息系统（GIS）平台",
      "operatingSystem": "银河麒麟高级服务器操作系统v10（openEuler商业发行版）",
      "description": "STARGIS EARTH平台基于银河麒麟高级服务器操作系统v10（openEuler商业发行版操作系统）构建，提供多维空间信息管理服务，支持城市规划、资源管理和环境监测等关键领域。",
      "featureList": [
        "全栈性能调优：基于openEuler系操作系统和openGauss数据库进行全栈性能调优",
        "多维空间信息整合：高效管理和分析地理空间数据",
        "高并发高吞吐量服务：支持大规模空间数据处理",
        "流畅加载渲染：优化大范围高精细模型的加载和渲染能力",
        "空间体拓扑运算：支持复杂的空间分析",
        "地下空间建模：地下空间实体语义化实时建模"
      ]
    }
