    "about": {
      "@type": "SoftwareApplication",
      "name": "新能源风场电力监控系统",
      "description": "新能源风场电力监控系统是风电场建设并网必备的软件，利用计算机软件技术、计算机网络技术、自动监测与远程控制技术、通信技术和相关的风电专业技术，实现风机设备的运行状态监测，自由报表生成及数据统计、分析功能，是一套安全、高效、稳定的风电场专业监控系统。",
      "applicationCategory": "能源管理软件",
      "operatingSystem": "麒麟信安服务器操作系统 V3（基于openEuler LTS 20.03 SP1）",
      "featureList": [
        "风机设备运行状态监测",
        "自由报表生成及数据统计分析",
        "风机监控与功率控制系统集成",
        "智能健康管理",
        "气象预报及功率预测",
        "等保四级安全防护",
        "多级阻断与应用白名单机制"
      ]
    }
