        "position": 1,
        "itemListElement": [
          {
            "@type": "HowToStep",
            "position": 1,
            "name": "注册AtomGit账号",
            "text": "参考相关文档注册AtomGit账号。",
            "url": "https://www.openeuler.org/zh/interaction/post-blog"
          },
          {
            "@type": "HowToStep",
            "position": 2,
            "name": "设置主邮箱地址",
            "text": "在AtomGit个人设置中设置主邮箱地址。",
            "url": "https://www.openeuler.org/zh/interaction/post-blog"
          },
          {
            "@type": "HowToStep",
            "position": 3,
            "name": "签署贡献者协议",
            "text": "签署CLA（贡献者许可协议）。",
            "url": "https://www.openeuler.org/zh/interaction/post-blog"
          },
          {
            "@type": "HowToStep",
            "position": 4,
            "name": "准备git环境",
            "text": "按照文档指引配置本地git开发环境。",
            "url": "https://www.openeuler.org/zh/interaction/post-blog"
          }
        ]
      },
      {
        "@type": "HowToSection",
        "name": "理解博客格式",
        "position": 2,
        "itemListElement": [
          {
            "@type": "HowToStep",
            "position": 1,
            "name": "了解Markdown博客格式",
            "text": "openEuler使用Markdown格式写博客，文件头需包含title、date、category、tags、sig、author、summary等字段。",
            "url": "https://www.openeuler.org/zh/interaction/post-blog"
          },
          {
            "@type": "HowToStep",
            "position": 2,
            "name": "遵守格式规则",
            "text": "文件名禁止含+号，图片命名禁止空格且大小写敏感，避免使用已弃用的HTML标签，HTML标签需闭合，暂不支持c++代码块语言标识。",
            "url": "https://www.openeuler.org/zh/interaction/post-blog"
          }
        ]
      },
      {
        "@type": "HowToSection",
        "name": "提交博客",
        "position": 3,
        "itemListElement": [
          {
            "@type": "HowToStep",
            "position": 1,
            "name": "Fork openEuler博客项目",
            "text": "在AtomGit上Fork openEuler-portal项目到自己的账号下。",
            "url": "https://www.openeuler.org/zh/interaction/post-blog"
          },
          {
            "@type": "HowToStep",
            "position": 2,
            "name": "Clone代码并创建分支",
            "text": "使用git clone克隆代码，并使用git checkout -b创建新分支。",
            "url": "https://www.openeuler.org/zh/interaction/post-blog"
          },
          {
            "@type": "HowToStep",
            "position": 3,
            "name": "创建工作路径并撰写博客",
            "text": "在app/zh/blog目录下以AtomGit账号为名创建文件夹，并以YEAR-MONTH-DAY-title.md格式命名博客文件。",
            "url": "https://www.openeuler.org/zh/interaction/post-blog"
          },
          {
            "@type": "HowToStep",
            "position": 4,
            "name": "提交Pull Request",
            "text": "完成博客撰写后，通过AtomGit的PR（Pull Request）流程提交博客到openEuler社区。",
            "url": "https://www.openeuler.org/zh/interaction/post-blog"
          }
        ]
      }
    ]
