  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "url": "https://www.openeuler.openatom.cn/zh/sig/role-description",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "openEuler SIG组有哪些角色？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "openEuler SIG组的主要角色包括：Maintainer（维护者，负责代码最终审核与合并）、Committer（提交者，拥有特定范围的合并权限）、Contributor（贡献者，通过PR参与代码贡献）。"
        }
      },
      {
        "@type": "Question",
        "name": "如何成为openEuler SIG组的Maintainer？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "成为Maintainer需要经过长期高质量贡献积累，由现有Maintainer推荐并经SIG组讨论通过后任命。Maintainer负责代码审核、版本发布和SIG组发展方向决策。"
        }
      },
      {
        "@type": "Question",
        "name": "Contributor和Committer有什么区别？",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Contributor通过提交Pull Request参与代码贡献，但不拥有代码合并权限；Committer经过长期贡献后获得特定模块的代码合并权限，可以审核并合并其他Contributor的PR。"
        }
      }
    ]
  }
